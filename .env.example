# Anthropic API Key — obtenha em https://console.anthropic.com
ANTHROPIC_API_KEY=sua_chave_aqui

# Supabase — obtenha em https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_aqui

# Evolution API — URL do seu servidor Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_api_key_evolution
INSTANCE_NAME=nome_da_sua_instancia

# Porta do servidor (opcional, padrão 3000)
PORT=3000
